{
    "name": "switon/session",
    "description": "Redis-backed HTTP session state with deferred writes and lifecycle events for Switon Framework",
    "type": "library",
    "keywords": [
        "switon",
        "session",
        "http",
        "cookies"
    ],
    "homepage": "https://github.com/switon-php/session",
    "license": "MIT",
    "authors": [
        {
            "name": "switon",
            "email": "admin@switon.dev"
        }
    ],
    "support": {
        "source": "https://github.com/switon-php/session",
        "issues": "https://github.com/switon-php/session/issues",
        "docs": "https://docs.switon.dev/latest/session"
    },
    "require": {
        "php": ">=8.3",
        "psr/event-dispatcher": "^1.0",
        "switon/core": "^1.0",
        "switon/event": "^1.0",
        "switon/http": "^1.0",
        "switon/redis": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "switon/testing": "^1.0",
        "phpstan/extension-installer": "^1.4"
    },
    "config": {
        "allow-plugins": {
            "switon/composer-extra": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "Switon\\Session\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Switon\\Session\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "@php vendor/bin/phpstan analyse",
        "test:unit": "@php vendor/bin/phpunit --configuration tests/phpunit.xml.dist --testsuite=unit --display-deprecations --display-phpunit-notices",
        "test": "@php vendor/bin/phpunit --configuration tests/phpunit.xml.dist --testsuite=all --display-deprecations --display-phpunit-notices"
    },
    "extra": {
        "switon": {
            "providers": [
                "Switon\\Session\\ServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-dev": "1.0.x-dev"
        }
    }
}
